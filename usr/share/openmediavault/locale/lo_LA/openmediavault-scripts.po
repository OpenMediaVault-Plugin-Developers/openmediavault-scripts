msgid "Add"
msgstr "ເພີ່ມ"

msgid "Add Python"
msgstr "ເພີ່ມ Python"

msgid "Add from URL"
msgstr "ເພີ່ມຈາກ URL"

msgid ""
"Are you sure you want to create a new git repo?  This will erase all "
"history!"
msgstr ""
"ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການສ້າງ git repo ໃໝ່? ການເຮັດແບບນີ້ຈະລຶບປະຫວັດທັງໝົດ!"

msgid "Are you sure you want to sync changes from the file?"
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການຊິງຄ໌ການປ່ຽນແປງຈາກໄຟລ໌?"

msgid "Changes have been synced from file."
msgstr "ການປ່ຽນແປງໄດ້ຖືກຊິງຄ໌ຈາກໄຟລ໌ແລ້ວ."

msgid "Create"
msgstr "ສ້າງ"

msgid "Created scheduled job."
msgstr "ສ້າງໜ້າວຽກທີ່ກຳນົດເວລາແລ້ວ."

msgid "Created script."
msgstr "ສ້າງສະຄຣິບແລ້ວ."

msgid "Docs"
msgstr "ເອກະສານ"

msgid "Downloading script ..."
msgstr "ກຳລັງດາວໂຫຼດສະຄຣິບ ..."

msgid "Edit"
msgstr "ແກ້ໄຂ"

msgid "Edit Python"
msgstr "ແກ້ໄຂ Python"

msgid "Edit scheduled job."
msgstr "ແກ້ໄຂໜ້າວຽກທີ່ກຳນົດເວລາ."

msgid "Edit shell script."
msgstr "ແກ້ໄຂ shell script."

msgid "File size"
msgstr "ຂະໜາດໄຟລ໌"

msgid "Git"
msgstr "Git"

msgid "Import"
msgstr "ນຳເຂົ້າ"

msgid "Import existing scripts ..."
msgstr "ນຳເຂົ້າສະຄຣິບທີ່ມີຢູ່ ..."

msgid "Import one"
msgstr "ນຳເຂົ້າອັນດຽວ"

msgid "Import one existing script ..."
msgstr "ນຳເຂົ້າສະຄຣິບທີ່ມີຢູ່ອັນໜຶ່ງ ..."

msgid "Initialize new git repo ..."
msgstr "ເລີ່ມຕົ້ນ git repo ໃໝ່ ..."

msgid "Logs"
msgstr "ບັນທຶກເຫດການ"

msgid "Name"
msgstr "ຊື່"

msgid "Number of separate compressed logs to keep"
msgstr "ຈຳນວນໄຟລ໌ບັນທຶກທີ່ບີບອັດແຍກກັນເພື່ອເກັບໄວ້"

msgid "Number of units before delete"
msgstr "ຈຳນວນໜ່ວຍກ່ອນຈະລຶບ"

msgid "Optional. Will use downloaded name if one is not specified."
msgstr "ທາງເລືອກ. ຈະໃຊ້ຊື່ທີ່ດາວໂຫຼດມາຫາກບໍ່ໄດ້ລະບຸຊື່."

msgid "Path"
msgstr "ເສັ້ນທາງ"

msgid "Remove empty log files?"
msgstr "ລຶບໄຟລ໌ບັນທຶກທີ່ວ່າງເປົ່າຫຼືບໍ່?"

msgid "Schedule"
msgstr "ກຳນົດເວລາ"

msgid "Script has been added."
msgstr "ສະຄຣິບຖືກເພີ່ມແລ້ວ."

msgid "Scripts"
msgstr "ສະຄຣິບ"

msgid "Settings"
msgstr "ການຕັ້ງຄ່າ"

msgid "Show all file changes ..."
msgstr "ສະແດງການປ່ຽນແປງຂອງໄຟລ໌ທັງໝົດ ..."

msgid "Sync changes from file"
msgstr "ຊິງຄ໌ການປ່ຽນແປງຈາກໄຟລ໌"

msgid "Syncing changes from file ..."
msgstr "ກຳລັງຊິງຄ໌ການປ່ຽນແປງຈາກໄຟລ໌ ..."

msgid "The field should only contain * or a comma separated list of values."
msgstr "ຊ່ອງນີ້ຄວນມີພຽງເຄື່ອງໝາຍ * ຫຼື ລາຍການຄ່າທີ່ຂັ້ນດ້ວຍຈຸດ."

msgid ""
"This will import one or more scripts in the selected folder.<br/>It will not"
" import any scripts that already exist in the plugin."
msgstr ""
"ສິ່ງນີ້ຈະນຳເຂົ້າໜຶ່ງ ຫຼື "
"ຫຼາຍສະຄຣິບໃນໂຟນເດີທີ່ເລືອກ.<br/>ມັນຈະບໍ່ນຳເຂົ້າສະຄຣິບໃດໆທີ່ມີຢູ່ໃນປລັກອິນແລ້ວ."

msgid ""
"This will import one script from the specified path.<br/>It will not import "
"a script that already exist in the plugin."
msgstr ""
"ສິ່ງນີ້ຈະນຳເຂົ້າໜຶ່ງສະຄຣິບຈາກເສັ້ນທາງທີ່ລະບຸ.<br/>ມັນຈະບໍ່ນຳເຂົ້າສະຄຣິບທີ່ມີຢູ່ໃນປລັກອິນແລ້ວ."

msgid "URL"
msgstr "URL"

msgid ""
"if you choose days, then the log files will be retained for this number of "
"days"
msgstr "ຫາກທ່ານເລືອກເປັນມື້, ໄຟລ໌ບັນທຶກຈະຖືກເກັບໄວ້ຕາມຈຳນວນມື້ນີ້"

msgid "if you choose yes then empty log files will be removed"
msgstr "ຫາກທ່ານເລືອກ ແມ່ນ ແລ້ວໄຟລ໌ບັນທຶກທີ່ວ່າງເປົ່າຈະຖືກລຶບອອກ"

msgid "init git repo"
msgstr "ເລີ່ມຕົ້ນ git repo"

msgid "show file changes"
msgstr "ສະແດງການປ່ຽນແປງຂອງໄຟລ໌"

msgid ""
"this is the number of files that will be kept, with a new file being created"
" each period"
msgstr "ນີ້ຄືຈຳນວນໄຟລ໌ທີ່ຈະຖືກເກັບໄວ້, ໂດຍຈະມີການສ້າງໄຟລ໌ໃໝ່ໃນແຕ່ລະຊ່ວງເວລາ"
