msgid "Add"
msgstr "Aggiungi"

msgid "Add Python"
msgstr "Aggiungi Python"

msgid "Add from URL"
msgstr "Aggiungi da URL"

msgid ""
"Are you sure you want to create a new git repo?  This will erase all "
"history!"
msgstr ""
"Sei sicuro di voler creare un nuovo repository Git? Questo cancellerà tutta "
"la cronologia!"

msgid "Are you sure you want to sync changes from the file?"
msgstr "Sei sicuro di voler sincronizzare le modifiche dal file?"

msgid "Changes have been synced from file."
msgstr "Le modifiche sono state sincronizzate dal file."

msgid "Create"
msgstr "Crea"

msgid "Created scheduled job."
msgstr "Job pianificato creato."

msgid "Created script."
msgstr "Script creato."

msgid "Docs"
msgstr "Documentazione"

msgid "Downloading script ..."
msgstr "Download dello script in corso..."

msgid "Edit"
msgstr "Modifica"

msgid "Edit Python"
msgstr "Modifica Python"

msgid "Edit scheduled job."
msgstr "Modifica job pianificato."

msgid "Edit shell script."
msgstr "Modifica script shell."

msgid "File size"
msgstr "Dimensione file"

msgid "Git"
msgstr "Git"

msgid "Import"
msgstr "Importa"

msgid "Import existing scripts ..."
msgstr "Importa script esistenti..."

msgid "Import one"
msgstr "Importa uno"

msgid "Import one existing script ..."
msgstr "Importa uno script esistente..."

msgid "Initialize new git repo ..."
msgstr "Inizializza un nuovo repository Git..."

msgid "Logs"
msgstr "Log"

msgid "Name"
msgstr "Nome"

msgid "Number of separate compressed logs to keep"
msgstr "Numero di log compressi separati da conservare"

msgid "Number of units before delete"
msgstr "Numero di elementi prima dell’eliminazione"

msgid "Optional. Will use downloaded name if one is not specified."
msgstr ""
"Opzionale. Verrà utilizzato il nome scaricato se non ne viene specificato "
"uno."

msgid "Path"
msgstr "Percorso"

msgid "Remove empty log files?"
msgstr "Rimuovere i file di log vuoti?"

msgid "Schedule"
msgstr "Pianificazione"

msgid "Script has been added."
msgstr "Script aggiunto."

msgid "Scripts"
msgstr "Script"

msgid "Settings"
msgstr "Impostazioni"

msgid "Show all file changes ..."
msgstr "Mostra tutte le modifiche ai file..."

msgid "Sync changes from file"
msgstr "Sincronizza le modifiche dal file"

msgid "Syncing changes from file ..."
msgstr "Sincronizzazione delle modifiche dal file in corso..."

msgid "The field should only contain * or a comma separated list of values."
msgstr ""
"Il campo deve contenere solo * oppure un elenco di valori separati da "
"virgola."

msgid ""
"This will import one or more scripts in the selected folder.<br/>It will not"
" import any scripts that already exist in the plugin."
msgstr ""
"Questo importerà uno o più script nella cartella selezionata.<br/>Non "
"verranno importati gli script già presenti nel plugin."

msgid ""
"This will import one script from the specified path.<br/>It will not import "
"a script that already exist in the plugin."
msgstr ""
"Questo importerà uno script dal percorso specificato.<br/>Non verrà "
"importato uno script già presente nel plugin."

msgid "URL"
msgstr "URL"

msgid ""
"if you choose days, then the log files will be retained for this number of "
"days"
msgstr ""
"Se scegli i giorni, i file di log saranno conservati per questo numero di "
"giorni."

msgid "if you choose yes then empty log files will be removed"
msgstr "Se scegli Sì, i file di log vuoti saranno rimossi."

msgid "init git repo"
msgstr "Inizializza repository Git"

msgid "show file changes"
msgstr "Mostra modifiche ai file"

msgid ""
"this is the number of files that will be kept, with a new file being created"
" each period"
msgstr ""
"questo è il numero di file che saranno conservati, con la creazione di un "
"nuovo file a ogni periodo"
